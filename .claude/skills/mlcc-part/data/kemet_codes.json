{
  "_comment": "KEMET C-spec part-number grammar (the C0805 / C1206 standard format). Used for typical commercial MLCC. KEMET has many other formats (HP, KGM, T520, etc.) — this only covers the C-spec.",
  "vendor": "KEMET",
  "prefix": "C",
  "fields": [
    { "name": "prefix",        "start": 0,  "len": 1 },
    { "name": "size",          "start": 1,  "len": 4, "note": "EIA, e.g., 0805" },
    { "name": "case_style",    "start": 5,  "len": 1, "note": "C = standard, A/B/E = special" },
    { "name": "capacitance",   "start": 6,  "len": 3 },
    { "name": "tolerance",     "start": 9,  "len": 1 },
    { "name": "voltage",       "start": 10, "len": 2 },
    { "name": "dielectric",    "start": 12, "len": 1 },
    { "name": "termination",   "start": 13, "len": 1, "optional": true },
    { "name": "packaging",     "start": 14, "len": 1, "optional": true }
  ],
  "size_to_case": {
    "0201": "0201_0603",
    "0402": "0402_1005",
    "0603": "0603_1608",
    "0805": "0805_2012",
    "1206": "1206_3216",
    "1210": "1210_3225",
    "1812": "1812_4532",
    "1825": "1812_4532",
    "2220": "2220_5750"
  },
  "voltage": {
    "5R": 4.0,  "5C": 6.3,  "8C": 10,  "1C": 16,  "3R": 25,
    "5G": 35,   "5R": 50,   "1H": 50,  "1K": 100, "2W": 200,
    "3K": 250,  "5G": 500,  "1Y": 630, "1J": 1000
  },
  "dielectric_to_class": {
    "G": "C0G",
    "R": "X7R",
    "A": "X5R",
    "P": "X8R",
    "U": "Y5V"
  },
  "tolerance": {
    "B": "±0.1 pF", "C": "±0.25 pF", "D": "±0.5 pF",
    "F": "±1%", "G": "±2%", "J": "±5%", "K": "±10%", "M": "±20%", "Z": "+80/-20%"
  }
}
